# ---- Runtime ----
APP_ENV=development            # development | production
PORT=8080
LOG_LEVEL=info                 # debug | info | warn | error

# ---- Database ----
DATABASE_URL=postgres://postgres:postgres@localhost:5432/blog?sslmode=disable
# Per-session Postgres statement_timeout in milliseconds (bounds slow queries).
STATEMENT_TIMEOUT_MS=10000

# ---- Auth (JWT) ----
# REQUIRED in production. In development a loud insecure default is used if empty.
JWT_SECRET=
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h         # 7 days
# Single admin seeded on boot / via cmd/seed. Rotate ADMIN_PASSWORD after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please

# ---- Media storage ----
STORAGE_DRIVER=local           # local | supabase | s3
STORAGE_PATH=storage/uploads
MEDIA_MAX_BYTES=5242880        # 5 MiB
# Required when STORAGE_DRIVER=supabase:
SUPABASE_URL=https://xyz.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=blog-media

# ---- Public URLs & cache revalidation webhook (to the Next.js frontend) ----
PUBLIC_BASE_URL=http://localhost:3000
REVALIDATE_URL=http://localhost:3000/api/revalidate
REVALIDATE_SECRET=

# ---- CORS & rate limiting ----
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_RPS=20
