# Production env for the VPS. Copy to ".env" next to docker-compose.prod.yml on
# the server and fill in real values. NEVER commit the filled-in .env.
#
#   cp .env.production.example .env && nano .env
#
# The Deploy workflow only ships docker-compose.prod.yml; this .env is managed
# by you on the VPS and is read automatically by `docker compose`.

# ---- Image selection --------------------------------------------------------
# REGISTRY defaults to ghcr.io/rivaelmanurung in the compose file; override only
# if you host images elsewhere. IMAGE_TAG is injected by the Deploy workflow
# (defaults to "latest"); pin a specific tag here for manual rollbacks.
# REGISTRY=ghcr.io/rivaelmanurung
IMAGE_TAG=latest

# ---- Postgres ---------------------------------------------------------------
POSTGRES_USER=blog
POSTGRES_PASSWORD=change-me-strong-db-password
POSTGRES_DB=blog

# ---- Runtime ----------------------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_RPS=20

# ---- Auth (REQUIRED — compose fails to start if any is empty) ---------------
JWT_SECRET=change-me-32-characters-minimum-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-me-strong-admin-password

# ---- Media storage (Supabase) ----------------------------------------------
STORAGE_DRIVER=supabase
MEDIA_MAX_BYTES=5242880
SUPABASE_URL=https://sgtvblebakqdfjebspss.supabase.co
SUPABASE_KEY=your-supabase-service-role-key
SUPABASE_BUCKET=PersonalBlog

# ---- Public URLs (REQUIRED) -------------------------------------------------
# Public origin of the frontend as seen by browsers.
PUBLIC_BASE_URL=https://blog.your-domain.com
# Explicit CORS allowlist (no '*' allowed in production).
CORS_ORIGINS=https://blog.your-domain.com
# Cache-revalidation webhook to the Next.js app (internal network name is fine).
REVALIDATE_URL=http://frontend:3000/api/revalidate
REVALIDATE_SECRET=change-me-shared-revalidate-secret

# ---- Frontend ---------------------------------------------------------------
# Server-only base URL of the Go backend (internal Docker network name).
BACKEND_URL=http://backend:8080
# NOTE: NEXT_PUBLIC_* are baked at image BUILD time (repo Variables in CI).
# These runtime values only affect server-side reads — keep them consistent.
NEXT_PUBLIC_SITE_URL=https://blog.your-domain.com
NEXT_PUBLIC_MEDIA_ORIGIN=https://sgtvblebakqdfjebspss.supabase.co

# ---- Host port mappings (optional; put a reverse proxy in front) -------------
BACKEND_PORT=8080
FRONTEND_PORT=3000
