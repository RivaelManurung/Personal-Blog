# Production env for the VPS. Copy to ".env" next to docker-compose.prod.yml on
# the server and fill in real values. NEVER commit the filled-in .env.
#
#   cp .env.production.example .env && nano .env
#
# The database is Supabase Postgres (external) — there is no local db container.

# ---- Image selection --------------------------------------------------------
# REGISTRY defaults to ghcr.io/rivaelmanurung in the compose file. IMAGE_TAG is
# injected by the Deploy workflow (defaults to "latest"); pin a tag here for
# manual rollbacks. FRONTEND_PORT is the public port the site is served on.
# REGISTRY=ghcr.io/rivaelmanurung
IMAGE_TAG=latest
FRONTEND_PORT=3000

# ---- Database (Supabase session pooler, REQUIRED) ---------------------------
# The '&' in the password is URL-encoded as %26.
DATABASE_URL=postgres://postgres.<ref>:<url-encoded-password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# ---- Auth (REQUIRED — compose fails to start if any is empty) ---------------
JWT_SECRET=change-me-32-characters-minimum-random-secret
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
ADMIN_EMAIL=admin@your-domain.com
ADMIN_PASSWORD=change-me-strong-admin-password

# ---- Media storage (Supabase, REQUIRED) -------------------------------------
STORAGE_DRIVER=supabase
MEDIA_MAX_BYTES=5242880
SUPABASE_URL=https://<ref>.supabase.co
SUPABASE_KEY=your-supabase-service-role-or-secret-key
SUPABASE_BUCKET=PersonalBlog

# ---- Public URLs (REQUIRED) -------------------------------------------------
# The public origin of the site as seen by browsers (IP:port now, a domain later).
PUBLIC_BASE_URL=http://YOUR_SERVER_IP:3000
CORS_ORIGINS=http://YOUR_SERVER_IP:3000
REVALIDATE_URL=http://frontend:3000/api/revalidate
REVALIDATE_SECRET=change-me-shared-revalidate-secret

# ---- Frontend ---------------------------------------------------------------
# Server-only backend URL (internal Docker network name — do not change).
BACKEND_URL=http://backend:8080
# NEXT_PUBLIC_* are baked at image BUILD time (GitHub repo Variables). These
# runtime values only affect server-side reads — keep them consistent.
NEXT_PUBLIC_SITE_URL=http://YOUR_SERVER_IP:3000
NEXT_PUBLIC_MEDIA_ORIGIN=https://<ref>.supabase.co

# ---- Operational ------------------------------------------------------------
LOG_LEVEL=info
RATE_LIMIT_RPS=20
STATEMENT_TIMEOUT_MS=10000
