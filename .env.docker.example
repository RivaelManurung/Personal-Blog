# Copy to .env at the repo root and adjust before running `docker compose up`.
# docker compose automatically reads a root .env file for ${VAR} interpolation.
# All values have safe-ish defaults in docker-compose.yml; override anything here.

# ---- Postgres ----
POSTGRES_USER=blog
POSTGRES_PASSWORD=blog
POSTGRES_DB=blog
DB_PORT=5432            # host port mapped to the db container

# ---- Backend (Go) ----
BACKEND_PORT=8080       # host port mapped to the backend container
LOG_LEVEL=info
# REQUIRED in production. Use a long random string (>= 32 chars).
JWT_SECRET=dev-insecure-change-me-32-characters-minimum
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL=168h
# Admin user seeded on boot. Rotate ADMIN_PASSWORD after first login.
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-please
STORAGE_DRIVER=local
MEDIA_MAX_BYTES=5242880
RATE_LIMIT_RPS=20

# Public origin of the FRONTEND as seen by browsers (REQUIRED in production).
PUBLIC_BASE_URL=http://localhost:3000
# Cache-revalidation webhook target (backend -> frontend, internal network).
REVALIDATE_URL=http://frontend:3000/api/revalidate
# Shared secret for the revalidation webhook (must match on both services).
REVALIDATE_SECRET=change-me
# Explicit CORS allowlist (no '*' in production).
CORS_ORIGINS=http://localhost:3000

# ---- Frontend (Next.js) ----
FRONTEND_PORT=3000      # host port mapped to the frontend container
# Server-only backend base URL (internal docker network name).
BACKEND_URL=http://backend:8080
# Public site origin (metadata, sitemap, canonical).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Public backend origin for media <img> src. MUST be browser-reachable, so use
# the PUBLIC backend URL (e.g. http://localhost:8080), NOT http://backend:8080.
NEXT_PUBLIC_MEDIA_ORIGIN=http://localhost:8080
